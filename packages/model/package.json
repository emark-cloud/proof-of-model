{
  "name": "@proof/model",
  "version": "0.0.0",
  "private": true,
  "description": "TS reference net: deterministic fixed-point inference, Poseidon-Merkle trace (R), weight root (H_w), openPath(ρ).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx ./src/*.test.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@proof/shared": "workspace:*",
    "poseidon-lite": "^0.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

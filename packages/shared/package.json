{
  "name": "@proof/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Single source of truth: fixed-point Q-format, Poseidon params, network shape, ABIs, deployed addresses.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./abis/*": "./src/abis/*"
  },
  "files": ["dist", "src/abis"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx ./src/*.test.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "poseidon-lite": "^0.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

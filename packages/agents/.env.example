# Agent runtime config (§1.5). Copy to .env and fill with FUNDED Arbitrum Sepolia keys.
# NEVER commit real keys. Each identity needs Sepolia ETH; providers also need stake (≥ MIN_STAKE).

# Distinct private keys per actor (0x-prefixed or bare hex).
PROVIDER_HONEST=
PROVIDER_CHEAT=
BUYER=
CHALLENGER=

# Optional RPC override (defaults to viem's public Arbitrum Sepolia endpoint).
SEPOLIA_RPC_URL=

# Provider service ports (honest / cheat run as separate processes).
PROVIDER_HONEST_PORT=4031
PROVIDER_CHEAT_PORT=4032

# x402 rail (DEFERRED — Arbitrum One). Only needed for the x402 buyer path.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

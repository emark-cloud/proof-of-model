# Phase-0 x402 CDP facilitator spike — copy to `.env` and fill in.
# Rail: Arbitrum One mainnet (eip155:42161). CDP has NO Arbitrum Sepolia support.

# --- CDP hosted facilitator credentials (https://portal.cdp.coinbase.com) ---
# Read by @coinbase/x402 `facilitator` to authenticate against the CDP x402 endpoint.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- Seller (x402-server.mjs) ---
# Address that receives the USDC. Can equal the buyer for a self-test (pays itself).
PAY_TO=0x2a3080AA52DE07702dd30b81cC97C3527e605B6A
PORT=4021

# --- Buyer (x402-client.mjs) ---
# Private key of a wallet holding native USDC on Arbitrum One (no ETH needed —
# the facilitator settles + sponsors gas). 0x2a30… already holds ~2.05 USDC.
PRIVATE_KEY=
RESOURCE_URL=http://localhost:4021/hello

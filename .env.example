# Phase-2 agent E2E — Arbitrum Sepolia (see phase2-plan.md §1.5, §2.3).
# Copy to `.env` and fill with FOUR distinct, funded Sepolia keys. Never commit `.env`.
#
# Funding (faucets in resources.md): each account needs gas; the two provider
# accounts additionally need ≥ MIN_STAKE (0.001 ETH) to register; the buyer needs
# the per-inference FEE (0.00002 ETH). `pnpm fund-check` asserts all of this.

# RPC endpoint for Arbitrum Sepolia (optional — viem falls back to a public RPC).
SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Phase-1 deployer key — holds Sepolia ETH; `pnpm fund` disperses to the 4 agents
# below (which `pnpm fund` auto-generates on first run). Only needed for funding.
DEPLOYER_KEY=0x

# Provider identities (need gas + stake). Honest serves the real model; cheat
# corrupts one neuron (== buildBadFixture) and gets slashed.
PROVIDER_HONEST_KEY=0x
PROVIDER_CHEAT_KEY=0x

# Buyer pays the escrowed fee per inference (needs gas + FEE).
BUYER_KEY=0x

# Challenger samples paths, calls the Verifier, and slashes proven cheats (needs gas).
CHALLENGER_KEY=0x
